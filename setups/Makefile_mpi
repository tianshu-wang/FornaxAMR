CC := $(shell command -v mpicc >/dev/null 2>&1 && echo mpicc || echo cc)
STD := -std=c99
WARN := -Wall -Wextra -pedantic
MPI_CFLAGS := $(shell mpicc --showme:compile 2>/dev/null)
MPI_LIBS := $(shell mpicc --showme:link 2>/dev/null)
CPPFLAGS := -Isrc -DPRJ_ENABLE_MPI $(MPI_CFLAGS)
CFLAGS := $(STD) $(WARN) -O2
LDLIBS := $(MPI_LIBS)

CORE_SRCS := \
	src/prj_amr.c \
	src/prj_boundary.c \
	src/prj_eos.c \
	src/prj_flux.c \
	src/prj_gravity.c \
	src/prj_mesh.c \
	src/prj_mpi.c \
	src/prj_reconstruct.c \
	src/prj_riemann.c \
	src/prj_src.c \
	src/prj_timeint.c \
	src/prj_utils.c \
	problems/prj_problem_general.c \
	problems/prj_problem_sedov.c \
	problems/prj_problem_sedov_offcenter.c

CORE_OBJS := $(CORE_SRCS:.c=.o)
TEST_BIN := build/test_mpi

$(TEST_BIN): tests/test_mpi.c $(CORE_OBJS)
	@mkdir -p build
	$(CC) $(CPPFLAGS) $(CFLAGS) $< $(CORE_OBJS) $(LDLIBS) -o $@

.PHONY: test_mpi

test_mpi: $(TEST_BIN)
