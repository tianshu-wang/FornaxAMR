SHELL := /bin/zsh
CC := cc
STD := -std=c99
WARN := -Wall -Wextra -pedantic
CPPFLAGS := -Isrc
CFLAGS := $(STD) $(WARN) -O3
LDFLAGS :=
LDLIBS := -lm

TEST_SRC := tests/test_eos.c
TEST_BIN := tests/test_eos
EOS_SRC := src/prj_eos.c
EOS_OBJ := src/prj_eos.o

.PHONY: all run clean

all: $(TEST_BIN)

$(EOS_OBJ): $(EOS_SRC) src/prj_eos.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(TEST_BIN): $(TEST_SRC) $(EOS_OBJ)
	$(CC) $(CPPFLAGS) $(CFLAGS) $< $(EOS_OBJ) $(LDFLAGS) $(LDLIBS) -o $@

run: $(TEST_BIN)
	./$(TEST_BIN)

clean:
	rm -f $(EOS_OBJ) $(TEST_BIN)
