SHELL := /bin/zsh
CC := cc
STD := -std=c99
WARN := -Wall -Wextra -pedantic
HDF5_CFLAGS := $(shell pkg-config --cflags hdf5)
HDF5_LIBS := $(shell pkg-config --libs hdf5)
CPPFLAGS := -Isrc $(HDF5_CFLAGS)
CFLAGS := $(STD) $(WARN) -O3
LDFLAGS :=
LDLIBS := $(HDF5_LIBS)

TEST_SRC := tests/test_io.c
TEST_BIN := tests/test_io
IO_OBJ := src/prj_io.o
MESH_OBJ := src/prj_mesh.o
BOUNDARY_OBJ := src/prj_boundary.o
AMR_OBJ := src/prj_amr.o
EOS_OBJ := src/prj_eos.o
RECON_OBJ := src/prj_reconstruct.o

.PHONY: all run clean

all: $(TEST_BIN)

$(IO_OBJ): src/prj_io.c src/prj.h src/prj_io.h src/prj_mesh.h src/prj_boundary.h src/prj_amr.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(MESH_OBJ): src/prj_mesh.c src/prj.h src/prj_mesh.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(BOUNDARY_OBJ): src/prj_boundary.c src/prj.h src/prj_boundary.h src/prj_amr.h src/prj_mesh.h src/prj_reconstruct.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(AMR_OBJ): src/prj_amr.c src/prj.h src/prj_amr.h src/prj_mesh.h src/prj_eos.h src/prj_reconstruct.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(EOS_OBJ): src/prj_eos.c src/prj.h src/prj_eos.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(RECON_OBJ): src/prj_reconstruct.c src/prj.h src/prj_reconstruct.h src/prj_types.h src/prj_defs.h
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(TEST_BIN): $(TEST_SRC) $(IO_OBJ) $(MESH_OBJ) $(BOUNDARY_OBJ) $(AMR_OBJ) $(EOS_OBJ) $(RECON_OBJ)
	$(CC) $(CPPFLAGS) $(CFLAGS) $< $(IO_OBJ) $(MESH_OBJ) $(BOUNDARY_OBJ) $(AMR_OBJ) $(EOS_OBJ) $(RECON_OBJ) $(LDFLAGS) $(LDLIBS) -o $@

run: $(TEST_BIN)
	./$(TEST_BIN)

clean:
	rm -f $(IO_OBJ) $(MESH_OBJ) $(BOUNDARY_OBJ) $(AMR_OBJ) $(EOS_OBJ) $(RECON_OBJ) $(TEST_BIN)
